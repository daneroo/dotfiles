#!/usr/bin/env bash
# ghostty-sessions - Save and restore Ghostty terminal sessions
# Requires: macOS, Ghostty 1.3+, jq

set -euo pipefail

# Desired state: curated list of sessions to restore
# Actual state: captured from running Ghostty via `show`
# DEFAULT_FILE="${HOME}/.config/ghostty/sessions.json"
DEFAULT_FILE="${HOME}/.dotfiles/active-shells.json"

usage() {
    echo "Usage: ghostty-sessions <command> [file]"
    echo ""
    echo "Commands:"
    echo "  show           Show current Ghostty sessions"
    echo "  save [file]    Save current sessions to JSON (default: $DEFAULT_FILE)"
    echo "  restore [file] Select and restore a session from JSON"
    echo ""
    echo "Examples:"
    echo "  ghostty-sessions show"
    echo "  ghostty-sessions save"
    echo "  ghostty-sessions restore"
}

capture_sessions() {
    # Use JXA (JavaScript for Automation) for proper JSON serialization
    # Ghostty 1.3+ AppleScript API: windows > tabs > terminals
    #
    # Example output (2 windows, second has 2 tabs):
    # [
    #   { "tabs": [{ "title": "~/.dotfiles", "cwd": "/Users/daniel/.dotfiles" }] },
    #   { "tabs": [
    #       { "title": "project-a", "cwd": "/Users/daniel/Code/project-a" },
    #       { "title": "project-b", "cwd": "/Users/daniel/Code/project-b" }
    #   ]}
    # ]
    #
    # Title is pinned (via Edit Tab Title) or dynamic (cwd/running command)
    osascript -l JavaScript <<'EOF'
const app = Application('Ghostty');
const sessions = app.windows().map(w => ({
    tabs: w.tabs().map(t => ({
        title: t.name(),
        cwd: t.terminals()[0].workingDirectory()
    }))
}));
JSON.stringify(sessions);
EOF
}

cmd_save() {
    local file="${1:-$DEFAULT_FILE}"
    local dir
    dir=$(dirname "$file")

    # Ensure directory exists
    mkdir -p "$dir"

    # Capture and save
    capture_sessions | jq . > "$file"
    echo "Saved sessions to: $file"
}

cmd_show() {
    capture_sessions | jq .
}

cmd_restore() {
    local file="${1:-$DEFAULT_FILE}"

    if [[ ! -f "$file" ]]; then
        echo "Error: Session file not found: $file"
        exit 1
    fi

    # Build list of session titles
    local choices
    choices=$(jq -r '.[] | .tabs[] | .title' "$file")

    if [[ -z "$choices" ]]; then
        echo "No sessions found in $file"
        exit 1
    fi

    # Use gum to select
    local selected_title
    selected_title=$(echo "$choices" | gum choose --header "Select session to restore:")

    if [[ -z "$selected_title" ]]; then
        echo "No selection made"
        exit 0
    fi

    # Get cwd for the selected title
    local cwd
    cwd=$(jq -r --arg title "$selected_title" '
        .[] | .tabs[] | select(.title == $title) | .cwd
    ' "$file" | head -1)

    # Expand ~ to $HOME (Ghostty's --working-directory doesn't expand ~)
    cwd="${cwd/#\~/$HOME}"

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Selected: $selected_title"
    echo "Directory: $cwd"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Ask user to confirm before opening (prevents accidental window spawning)
    if gum confirm "Open new Ghostty window?"; then
        # Open new Ghostty window
        # -n spawns new instance (macOS limitation: no IPC to existing Ghostty for new window with args)
        local cwd_basename
        cwd_basename=$(basename "$cwd")
        if [[ "$selected_title" != "$cwd" && "$selected_title" != "$cwd_basename" ]]; then
            open -na Ghostty.app --args --working-directory="$cwd" --title="$selected_title"
        else
            open -na Ghostty.app --args --working-directory="$cwd"
        fi
        echo "Opened new window"
    else
        # User declined - provide command to copy manually as fallback
        echo ""
        echo "Copy and paste:"
        echo "  cd $cwd"
    fi
}

# Main
case "${1:-}" in
    show)
        cmd_show
        ;;
    save)
        cmd_save "${2:-}"
        ;;
    restore)
        cmd_restore "${2:-}"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        usage
        exit 1
        ;;
esac
